{
  "name": "@travelhub/api",
  "version": "0.1.0",
  "private": true,
  "description": "Travel Hub Armenia — backend API (Node.js/Express), implementing BACKEND_ARCHITECTURE.md.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects unit",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects unit",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects integration --forceExit --runInBand",
    "test:contract": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects contract --forceExit",
    "test:all": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "db:migrate": "node src/infrastructure/database/migrate.js up",
    "db:migrate:down": "node src/infrastructure/database/migrate.js down",
    "db:migrate:status": "node src/infrastructure/database/migrate.js status",
    "db:seed": "node src/infrastructure/database/seeds/index.js",
    "db:reset": "node src/infrastructure/database/reset.js"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "bullmq": "^5.28.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.4",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@travelhub/config": "*",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-boundaries": "^4.2.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  }
}
