# Travel Hub Armenia — apps/web environment variables.
# Copy this file to .env and fill in local/sandbox values.
# See SPRINT_0_IMPLEMENTATION_PLAN.md Chapter 14 and
# FRONTEND_ARCHITECTURE.md Chapter 37.
#
# CRITICAL: every variable here is compiled into publicly-served
# JavaScript (Vite's VITE_ prefix convention). NEVER place a secret,
# API key, or signing secret in this file or in any VITE_-prefixed
# variable — see FRONTEND_ARCHITECTURE.md §34.1 / §37.

VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_ENVIRONMENT_NAME=development
VITE_DEFAULT_LOCALE=hy
VITE_MONITORING_ENDPOINT=
VITE_MAPS_API_KEY=
